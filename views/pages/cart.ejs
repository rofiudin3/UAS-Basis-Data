<%- include('../partials/header') %>

<div class="max-w-3xl mx-auto">
  <div class="mb-6 flex items-center justify-between border-b border-steamBlue/20 pb-4">
    <h1 class="text-2xl font-bold tracking-wide text-white">KERANJANG BELANJA</h1>
    <a href="/" class="text-xs text-steamAccent hover:underline">← Kembali ke Toko</a>
  </div>

  <% if (!game) { %>
    <div class="bg-steamDark/80 p-12 rounded-lg border border-steamBlue/10 text-center shadow-lg">
      <div class="text-4xl mb-4">🛒</div>
      <p class="text-gray-300 text-lg mb-4">Keranjang belanja Anda kosong.</p>
      <a href="/" class="inline-block bg-steamBlue hover:bg-steamBlue/80 text-white text-sm font-bold py-2.5 px-6 rounded transition">
        Jelajahi Game
      </a>
    </div>
  <% } else { %>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Item Cart (Kiri) -->
      <div class="md:col-span-2 space-y-4">
        <div class="bg-steamCard p-4 rounded-lg border border-steamBlue/10 flex space-x-4 items-center">
          <img src="<%= game.image_url || 'https://via.placeholder.com/120x60/1b2838/ffffff?text=VaporVault' %>" 
               alt="<%= game.title %>" class="w-24 h-14 object-cover rounded">
          <div class="flex-grow">
            <h3 class="font-bold text-white"><%= game.title %></h3>
            <p class="text-xs text-gray-400">Lisensi Digital VaporVault</p>
          </div>
          <div class="text-right">
            <p class="font-bold text-white">
              <% if (parseFloat(game.price) === 0) { %>
                Gratis
              <% } else { %>
                Rp <%= parseFloat(game.price).toLocaleString('id-ID') %>
              <% } %>
            </p>
            <a href="/cart" class="text-xs text-rose-400 hover:text-rose-300 transition mt-1 block">Hapus</a>
          </div>
        </div>
      </div>

      <!-- Checkout Summary (Kanan) -->
      <div class="md:col-span-1 bg-steamDark/80 p-6 rounded-lg border border-steamBlue/20 h-fit shadow-lg space-y-6">
        <h2 class="text-sm font-bold uppercase tracking-wider text-gray-300">Rincian Pembayaran</h2>
        
        <div class="space-y-3 text-sm">
          <div class="flex justify-between text-gray-400">
            <span>Subtotal</span>
            <span>Rp <%= parseFloat(game.price).toLocaleString('id-ID') %></span>
          </div>
          <div class="flex justify-between text-gray-400">
            <span>Pajak (PPN 0%)</span>
            <span>Rp 0</span>
          </div>
          <hr class="border-steamBlue/10">
          <div class="flex justify-between text-white font-bold">
            <span>Total Tagihan</span>
            <span class="text-steamAccent">Rp <%= parseFloat(game.price).toLocaleString('id-ID') %></span>
          </div>
        </div>

        <div class="p-3 bg-steamDarker rounded border border-steamBlue/10 text-xs">
          <div class="flex justify-between text-gray-400 mb-1">
            <span>Saldo Anda:</span>
            <span id="cart-balance-display">Rp <%= parseFloat(user.balance).toLocaleString('id-ID') %></span>
          </div>
          <% if (parseFloat(user.balance) < parseFloat(game.price)) { %>
            <div class="text-rose-400 font-semibold mt-1">⚠️ Saldo tidak mencukupi</div>
          <% } else { %>
            <div class="text-emerald-400 font-semibold mt-1">✓ Saldo mencukupi</div>
          <% } %>
        </div>

        <!-- Checkout Button -->
        <button id="btn-checkout" class="w-full bg-steamGreen hover:bg-steamGreenHover disabled:bg-gray-600 disabled:cursor-not-allowed text-white text-sm font-bold py-3 px-4 rounded transition tracking-wider shadow-lg"
                <%= parseFloat(user.balance) < parseFloat(game.price) ? 'disabled' : '' %>
                onclick="checkoutGame(<%= game.id %>)">
          CHECKOUT SEKARANG
        </button>

        <div id="checkout-message" class="hidden p-3 rounded text-xs font-semibold text-center border"></div>
      </div>
    </div>
  <% } %>
</div>

<script>
  // Sync saldo dari backend ke header navigation bar
  <% if (game && user) { %>
    document.getElementById('user-balance-display').innerText = 'Rp <%= parseFloat(user.balance).toLocaleString("id-ID") %>';
  <% } %>

  async function checkoutGame(gameId) {
    const btn = document.getElementById('btn-checkout');
    const msgBox = document.getElementById('checkout-message');
    
    btn.disabled = true;
    btn.innerText = 'MEMPROSES...';
    
    try {
      const response = await fetch('/api/purchase', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ gameId })
      });
      
      const result = await response.json();
      
      msgBox.classList.remove('hidden', 'bg-emerald-950/80', 'text-emerald-400', 'border-emerald-500/30', 'bg-rose-950/80', 'text-rose-400', 'border-rose-500/30');
      
      if (result.success) {
        msgBox.classList.add('block', 'bg-emerald-950/80', 'text-emerald-400', 'border-emerald-500/30');
        msgBox.innerText = result.message;
        
        // Update balance display
        document.getElementById('cart-balance-display').innerText = 'Rp ' + parseFloat(result.newBalance).toLocaleString('id-ID');
        document.getElementById('user-balance-display').innerText = 'Rp ' + parseFloat(result.newBalance).toLocaleString('id-ID');
        
        btn.innerText = 'BERHASIL DIBELI';
        
        // Redirect ke library dalam 2 detik
        setTimeout(() => {
          window.location.href = '/library';
        }, 2000);
      } else {
        msgBox.classList.add('block', 'bg-rose-950/80', 'text-rose-400', 'border-rose-500/30');
        msgBox.innerText = result.message;
        btn.disabled = false;
        btn.innerText = 'CHECKOUT SEKARANG';
      }
    } catch (error) {
      console.error('Error during checkout:', error);
      msgBox.classList.add('block', 'bg-rose-950/80', 'text-rose-400', 'border-rose-500/30');
      msgBox.innerText = 'Terjadi gangguan jaringan saat memproses checkout.';
      btn.disabled = false;
      btn.innerText = 'CHECKOUT SEKARANG';
    }
  }
</script>

<%- include('../partials/footer') %>
