<%- include('../partials/header') %>

<div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
  
  <!-- Sidebar Filter (Kiri) -->
  <aside class="lg:col-span-1 bg-steamDark/80 p-6 rounded-lg border border-steamBlue/10 h-fit shadow-lg backdrop-blur-sm">
    <h2 class="text-lg font-bold text-white mb-6 flex items-center space-x-2 border-b border-steamBlue/20 pb-3">
      <span>⚙️</span> <span>FILTER PUSTAKA</span>
    </h2>

    <form action="/" method="GET" class="space-y-6">
      <!-- Search Input -->
      <div>
        <label for="search" class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Cari Game</label>
        <div class="relative">
          <input type="text" id="search" name="search" value="<%= query.search || '' %>" placeholder="Cari judul game..." 
                 class="w-full bg-steamDarker border border-steamBlue/20 rounded px-3 py-2 text-sm text-white placeholder-gray-500 focus:outline-none focus:border-steamBlue transition">
        </div>
      </div>

      <!-- Category Filter -->
      <div>
        <label for="category" class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Kategori / Genre</label>
        <select id="category" name="category" 
                class="w-full bg-steamDarker border border-steamBlue/20 rounded px-3 py-2 text-sm text-white focus:outline-none focus:border-steamBlue transition">
          <option value="">Semua Kategori</option>
          <% categories.forEach(cat => { %>
            <option value="<%= cat.id %>" <%= query.category == cat.id ? 'selected' : '' %>><%= cat.name %></option>
          <% }) %>
        </select>
      </div>

      <!-- Max Price Filter -->
      <div>
        <label for="maxPrice" class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Harga Maksimal</label>
        <div class="flex items-center space-x-2">
          <span class="text-xs text-gray-400">Rp</span>
          <input type="number" id="maxPrice" name="maxPrice" value="<%= query.maxPrice || '' %>" placeholder="Misal: 200000" 
                 class="w-full bg-steamDarker border border-steamBlue/20 rounded px-3 py-2 text-sm text-white focus:outline-none focus:border-steamBlue transition">
        </div>
      </div>

      <!-- Action Buttons -->
      <div class="flex space-x-3 pt-2">
        <button type="submit" class="flex-grow bg-steamBlue hover:bg-steamBlue/80 text-white text-xs font-bold py-2.5 px-4 rounded transition tracking-wider">
          TERAPKAN
        </button>
        <a href="/" class="bg-steamButton hover:bg-slate-700 text-gray-300 text-xs font-bold py-2.5 px-4 rounded transition tracking-wider flex items-center justify-center">
          RESET
        </a>
      </div>
    </form>
  </aside>

  <!-- Store Games Grid (Kanan) -->
  <section class="lg:col-span-3">
    <div class="flex justify-between items-center mb-6">
      <h1 class="text-2xl font-bold tracking-wide text-white">
        <% if (query.search) { %>
          Hasil pencarian: "<%= query.search %>"
        <% } else { %>
          Jelajahi Game Terbaru
        <% } %>
      </h1>
      <span class="text-xs text-gray-400 bg-steamDark px-3 py-1.5 rounded border border-steamBlue/10"><%= games.length %> game ditemukan</span>
    </div>

    <% if (games.length === 0) { %>
      <div class="bg-steamDark/40 border border-dashed border-steamBlue/20 rounded-lg p-12 text-center">
        <p class="text-gray-400 text-lg mb-2">Tidak ada game yang sesuai dengan kriteria pencarian Anda.</p>
        <p class="text-xs text-gray-500">Coba hapus beberapa filter pencarian atau kata kunci di sebelah kiri.</p>
      </div>
    <% } else { %>
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
        <% games.forEach(game => { %>
          <div class="bg-steamCard rounded-lg overflow-hidden border border-steamBlue/10 hover:border-steamBlue/50 transition duration-300 flex flex-col group hover:shadow-lg shadow-black/50">
            <!-- Game Image Banner -->
            <div class="relative overflow-hidden h-40 bg-steamDark/80">
              <img src="<%= game.image_url || 'https://via.placeholder.com/460x215/1b2838/ffffff?text=VaporVault' %>" alt="<%= game.title %>" 
                   class="w-full h-full object-cover transform group-hover:scale-105 transition duration-500">
              <span class="absolute top-3 right-3 bg-steamDark/90 text-steamAccent px-2.5 py-1 rounded text-xs font-semibold uppercase tracking-wider border border-steamBlue/20 shadow-md">
                <%= game.category ? game.category.name : 'Game' %>
              </span>
            </div>

            <!-- Game Details -->
            <div class="p-5 flex flex-col flex-grow">
              <h3 class="text-lg font-bold text-white group-hover:text-steamAccent transition mb-2 truncate" title="<%= game.title %>">
                <%= game.title %>
              </h3>
              <p class="text-xs text-gray-400 line-clamp-3 mb-4 flex-grow leading-relaxed">
                <%= game.description %>
              </p>
              
              <!-- Price & Buy Action -->
              <div class="flex items-center justify-between mt-auto pt-4 border-t border-steamBlue/10">
                <span class="text-sm font-bold text-white">
                  <% if (parseFloat(game.price) === 0) { %>
                    <span class="text-emerald-400 uppercase tracking-widest text-xs">Gratis</span>
                  <% } else { %>
                    Rp <%= parseFloat(game.price).toLocaleString('id-ID') %>
                  <% } %>
                </span>
                
                <a href="/cart?gameId=<%= game.id %>" class="bg-steamGreen hover:bg-steamGreenHover text-white text-xs font-bold py-2 px-4 rounded transition duration-200 shadow-md shadow-emerald-900/20">
                  BELI SEKARANG
                </a>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </section>
  
</div>

<%- include('../partials/footer') %>
