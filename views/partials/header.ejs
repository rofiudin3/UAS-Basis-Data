<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- Google Font: Outfit -->
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['Outfit', 'sans-serif'],
          },
          colors: {
            steamDark: '#171a21',      // Latar belakang gelap pekat
            steamDarker: '#1b2838',    // Latar belakang utama Steam (biru gelap)
            steamBlue: '#1078ff',      // Biru neon aksen utama
            steamAccent: '#66c0f4',    // Biru muda aksen sekunder
            steamCard: '#1a2232',      // Latar belakang card game
            steamButton: '#2e3a51',    // Latar belakang tombol netral
            steamGreen: '#5c7e10',     // Hijau tombol beli
            steamGreenHover: '#79a314',// Hijau tombol beli (hover)
          }
        }
      }
    }
  </script>
  
  <style>
    body {
      background-color: #1b2838;
      color: #c7d5e0;
    }
    .neon-border {
      box-shadow: 0 0 10px rgba(16, 120, 255, 0.4);
    }
    .neon-text {
      text-shadow: 0 0 8px rgba(102, 192, 244, 0.6);
    }
  </style>
</head>
<body class="flex flex-col min-h-screen">
  <!-- Navbar Utama (Steam Inspired) -->
  <header class="bg-steamDark border-b border-steamBlue/20 sticky top-0 z-50 shadow-md">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <!-- Logo -->
        <div class="flex items-center space-x-3">
          <a href="/" class="flex items-center space-x-2">
            <svg class="h-8 w-8 text-steamAccent" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2C6.477 2 2 6.477 2 12c0 4.28 2.686 7.935 6.46 9.35l.89-3.23c-.22-.16-.41-.37-.55-.61L5.94 15.65c-.75-.75-.75-1.97 0-2.72l2.36-2.36c.64-.64 1.63-.73 2.37-.27l3.66-2.11c.2-.55.61-1.01 1.15-1.28.99-.49 2.21-.1 2.7 0.89s.1 2.21-.89 2.7c-.54.27-1.15.27-1.69.03l-3.66 2.11c-.02.43-.16.84-.4 1.18l-1.8 1.8c-.37.37-.97.37-1.34 0-.02-.02-.04-.04-.06-.06l-1.34-1.34c-.36-.36-.37-.95-.01-1.32l1.62-1.62c.16.27.4.49.69.63l.26.13c.27.13.57.19.87.19 1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2c0 .3.07.6.19.87l-.13-.26c-.14-.29-.36-.53-.63-.69l-1.62 1.62c.37.36.38.95.02 1.32L9.4 16.48c.16.22.37.41.61.55l.89-3.23C14.68 15.22 17.37 18.87 17.37 23.15 17.37 23.47 14.68 22 12 22 12 22 12 2z"/>
            </svg>
            <span class="text-xl font-bold tracking-wider text-white">VAPOR<span class="text-steamBlue neon-text">VAULT</span></span>
          </a>
        </div>

        <!-- Menu Navigation -->
        <nav class="hidden md:flex space-x-6 text-sm font-semibold tracking-wider">
          <a href="/" class="text-gray-300 hover:text-white transition duration-200 border-b-2 <%= title.includes('Store') ? 'border-steamBlue text-white' : 'border-transparent' %> pb-1 px-1">TOKO</a>
          <a href="/library" class="text-gray-300 hover:text-white transition duration-200 border-b-2 <%= title.includes('Library') ? 'border-steamBlue text-white' : 'border-transparent' %> pb-1 px-1">LIBRARY</a>
          <a href="/cart" class="text-gray-300 hover:text-white transition duration-200 border-b-2 <%= title.includes('Cart') ? 'border-steamBlue text-white' : 'border-transparent' %> pb-1 px-1 flex items-center space-x-1">
            <span>KERANJANG</span>
            <span class="bg-steamBlue/30 text-steamAccent px-1.5 py-0.5 rounded-full text-xs" id="nav-cart-badge">🛒</span>
          </a>
        </nav>

        <!-- User Info / Balance Demo -->
        <div class="flex items-center space-x-4">
          <div class="text-right hidden sm:block">
            <p class="text-xs text-gray-400">Saldo Demo</p>
            <p class="text-sm font-bold text-emerald-400" id="user-balance-display">Rp 500.000,00</p>
          </div>
          <div class="h-8 w-8 rounded bg-gradient-to-tr from-steamBlue to-steamAccent flex items-center justify-center font-bold text-white shadow-sm border border-steamBlue/40">
            U
          </div>
        </div>
      </div>
    </div>
  </header>
  
  <main class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-8">
